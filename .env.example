# ==============================================================================
# Django core
# ==============================================================================

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,testserver,.trycloudflare.com
SITE_URL=http://localhost:8000/dashboard/
ADMIN_URL=admin/

# ==============================================================================
# Database
# ==============================================================================

POSTGRES_DB=messaging_monitoring
POSTGRES_USER=messaging_monitoring
POSTGRES_PASSWORD=messaging_monitoring
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgres://messaging_monitoring:messaging_monitoring@db:5432/messaging_monitoring

# ==============================================================================
# Account / OAuth
# ==============================================================================

ACCOUNT_EMAIL_VERIFICATION=none
SOCIALACCOUNT_EMAIL_VERIFICATION=none

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ==============================================================================
# Gmail integration
# ==============================================================================

GMAIL_POLLING_ENABLED=True
GMAIL_POLLING_BEAT_MINUTE=*/5
GMAIL_MAX_MESSAGES_PER_SYNC=20
GMAIL_MAX_BODY_CHARS=8000
GMAIL_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly

# ==============================================================================
# Redis / Cache
# ==============================================================================

REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/2

# ==============================================================================
# Celery
# ==============================================================================

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ==============================================================================
# Digest notifications / Celery Beat
# ==============================================================================

DIGEST_NOTIFICATIONS_ENABLED=True
DIGEST_BEAT_MINUTE=5
DIGEST_BEAT_HOUR=*

# ==============================================================================
# Bootstrap superuser
# ==============================================================================

DJANGO_CREATE_SUPERUSER=True
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me-secure-password

# ==============================================================================
# Security / Encryption
# ==============================================================================

FIELD_ENCRYPTION_KEY=change-me

TURNSTILE_ENABLED=1
TURNSTILE_SITE_KEY=0x
TURNSTILE_SECRET_KEY=0x

CONTACT_FORM_RECIPIENT_EMAIL=tester1@gmail.com
CONTACT_FORM_RATE_LIMIT_PER_HOUR=5
DEFAULT_FROM_EMAIL=noreply@example.com

# ==============================================================================
# Telegram integration limits
# ==============================================================================

TELEGRAM_SOURCE_WEBHOOK_LIMIT_PER_MINUTE=120
TELEGRAM_PROFILE_WEBHOOK_LIMIT_PER_DAY=5000

# ==============================================================================
# Telegram customer anti-spam limits
# ==============================================================================

TELEGRAM_CLIENT_MESSAGE_INTERVAL_SECONDS=120
TELEGRAM_CLIENT_DAILY_MESSAGE_LIMIT=15
TELEGRAM_CLIENT_RATE_LIMIT_NOTICE_COOLDOWN_SECONDS=60

# ==============================================================================
# Telegram customer auto-replies
# ==============================================================================

TELEGRAM_CUSTOMER_AUTO_REPLY_ENABLED=True
TELEGRAM_CUSTOMER_AUTO_REPLY_COOLDOWN_SECONDS=300

# ==============================================================================
# Registered user rate limits
# ==============================================================================

REGISTERED_PROFILE_CREATE_LIMIT_PER_DAY=20
REGISTERED_EVENT_ACTION_LIMIT_PER_MINUTE=60

# ==============================================================================
# AI
# ==============================================================================

AI_ENABLED=True
OPENAI_API_KEY=sk-
OPENAI_MODEL=gpt-4o-mini
AI_PROMPT_VERSION=ai_v1
AI_REQUEST_TIMEOUT=20
AI_MIN_TEXT_LENGTH=12

AI_DAILY_CALL_LIMIT_PER_USER=50
AI_DAILY_COST_LIMIT_USD_PER_USER=0.05

AI_INPUT_COST_PER_1M_TOKENS=0.15
AI_OUTPUT_COST_PER_1M_TOKENS=0.60

# ==============================================================================
# Alerts
# ==============================================================================

ALERT_COOLDOWN_URGENT_SECONDS=0
ALERT_COOLDOWN_IMPORTANT_SECONDS=0