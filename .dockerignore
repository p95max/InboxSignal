# Git
.git/
.gitignore

# Python cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local env / secrets
.env
.env.*
!.env.example
!.env.*.example
secrets/
*.pem
*.key
*.crt

# Django runtime/generated files
db.sqlite3
db.sqlite3-journal
staticfiles/
static_root/
media/

# Logs
logs/
*.log

# Celery runtime
celerybeat-schedule
celerybeat.pid

# Database dumps / backups
*.sql
*.dump
*.backup
*.bak

# Telegram local sessions
*.session
*.session-journal
telegram.session*

# Docker/local runtime data
docker-data/
data/
tmp/
temp/

# IDE / OS
.idea/
.vscode/
.DS_Store
Thumbs.db

# Frontend artifacts, if added later
node_modules/
frontend/dist/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Optional docs/screenshots not needed in Docker image
docs/
screenshots/
*.md
!README.md